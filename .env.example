# Get your Anthropic API key from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get your Discord bot token from https://discord.com/developers/applications
# Create a new application, go to the Bot section, and copy the token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Get your Discord Guild (server) ID by enabling Developer Mode in Discord settings
# Then right-click your server name and select "Copy Server ID"
DISCORD_GUILD_ID=your_discord_guild_id_here

# Optional: Comma-separated list of Discord channel IDs to monitor
# Right-click a channel in Discord (with Developer Mode enabled) and select "Copy Channel ID"
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2,channel_id_3

# Get your Notion API key (Internal Integration Token) from https://www.notion.so/my-integrations
# Create a new integration and copy the "Internal Integration Token"
NOTION_API_KEY=your_notion_api_key_here

# The ID of the Notion database where knowledge base entries will be stored
# Open your Notion database in the browser and copy the ID from the URL
# URL format: https://www.notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=your_notion_database_id_here

# Optional: The ID of a parent Notion page under which new pages will be created
# Open the parent page in the browser and copy the ID from the URL
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id_here

# The application environment (development, staging, production)
APP_ENV=development

# Log level for the application (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Minimum number of messages in a thread before it is considered for summarization
MIN_MESSAGES_FOR_SUMMARY=5

# How often (in seconds) to check for new Discord activity to process
POLLING_INTERVAL_SECONDS=300

# Optional: Comma-separated list of Discord role IDs whose messages should be prioritized
# Right-click a role in Discord (with Developer Mode enabled) and select "Copy Role ID"
PRIORITY_ROLE_IDS=role_id_1,role_id_2

# Secret used to sign and verify internal webhook payloads (generate a strong random string)
WEBHOOK_SECRET=your_random_webhook_secret_here

# Host and port for the FastAPI application server
APP_HOST=0.0.0.0
APP_PORT=8000